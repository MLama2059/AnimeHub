@page "/animes"
@implements IDisposable
@using AnimeHub.Shared.Models.Dtos
@using AnimeHubClient.Services
@using Microsoft.AspNetCore.WebUtilities
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IAnimeService AnimeService
@inject AnimeStateContainer State
@inject ILookUpService LookUpService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudCard Elevation="0">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Align="Align.Center" Typo="Typo.h4" Class="fw-bold">Anime Catalog</MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudGrid Spacing="2" Class="align-content-center">
                @if (IsInitialLoading)
                {
                    <MudItem xs="12">
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12" md="3">
                        <MudTextField T="string"
                                      Label="Search"
                                      Placeholder="Search anime"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Immediate="true"
                                      Clearable="true"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Value="SearchInput"
                                      ValueChanged="OnSearchChanged" />
                    </MudItem>

                    @* Format Dropdown *@
                    <MudItem xs="6" md="2">
                        <MudSelect T="int?" Label="Format"
                                   Value="SelectedCategoryId"
                                   ValueChanged="async (val) => { SelectedCategoryId = val; await OnFilterChanged(); }"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Dense="true">
                            @foreach (var cat in _categories)
                            {
                                <MudSelectItem T="int?" Value="@cat.Id">@cat.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Genre Dropdown *@
                    <MudItem xs="6" md="2">
                        <MudSelect T="int?" Label="Genre"
                                   Value="SelectedGenreId"
                                   ValueChanged="async (val) => { SelectedGenreId = val; await OnFilterChanged(); }"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Dense="true">
                            @foreach (var genre in _genres)
                            {
                                <MudSelectItem T="int?" Value="@genre.Id">@genre.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Year Dropdown *@
                    <MudItem xs="6" md="2">
                        <MudSelect T="int?" Label="Year"
                                   Value="SelectedYear"
                                   ValueChanged="async (val) => { SelectedYear = val; await OnFilterChanged(); }"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Dense="true">
                            @foreach (var year in _years)
                            {
                                <MudSelectItem T="int?" Value="@year">@year</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Season Dropdown *@
                    <MudItem xs="6" md="2">
                        <MudSelect T="string" Label="Season"
                                   Value="SelectedSeason"
                                   ValueChanged="async (val) => { SelectedSeason = val; await OnFilterChanged(); }"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Dense="true">
                            @foreach (var season in _seasons)
                            {
                                <MudSelectItem T="string" Value="@season">@season</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Reset Button *@
                    <MudItem xs="12" md="1" Class="d-flex justify-center">
                        <MudIconButton Icon="@Icons.Material.Filled.FilterListOff"
                                       Color="Color.Error"
                                       OnClick="async () => { State.ClearCatalogState(); SearchInput = string.Empty; await OnFilterChanged(); }"
                                       Title="Clear Filters" />
                    </MudItem>
                }
            </MudGrid>
            
        </MudCardContent>
    </MudCard>

    @* Anime Card Grid *@
    <MudPaper Class="pa-6 section-paper" Elevation="4">
        @if (IsLoading && AnimesList.Count == 0)
        {
            <MudGrid Justify="Justify.Center">
                @for (int i = 0; i < 6; i++)
                {
                    <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                        <AnimeCardSkeleton />
                    </MudItem>
                }
            </MudGrid>
        }
        else if (AnimesList.Any())
        {
            <MudGrid Justify="Justify.Center" Spacing="4">
                @foreach (var anime in AnimesList)
                {
                    <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                        <AnimeCard Anime="anime" />
                    </MudItem>
                }
            </MudGrid>
        }
        else if (!IsLoading)
        {
            <MudText Align="Align.Center">No Results Found</MudText>
        }

        @* Infinite Scroll Skeletons - Shows only when fetching next page *@
        @if (IsLoading && AnimesList.Count > 0)
        {
            <MudGrid Justify="Justify.Center">
                @for (int i = 0; i < 6; i++)
                {
                    <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                        <AnimeCardSkeleton />
                    </MudItem>
                }
            </MudGrid>
        }

        @* Invisible trigger for Intersection Observer *@
        <div id="scroll-trigger" style="height: 50px;"></div>

        @if (!HasMorePages && AnimesList.Any())
        {
            <MudText Align="Align.Center" Class="py-4 text-muted fw-bold">
                You've reached the end of the catalog! (@AnimesList.Count total items)
            </MudText>
        }
    </MudPaper>
</MudContainer>

<MudScrollToTop>
    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowUpward" />
</MudScrollToTop>

@code {
    // State Redirection
    private List<AnimeListReadDto> AnimesList => State.CatalogItems;
    private string FilterQuery { get => State.CatalogSearchTerm; set => State.CatalogSearchTerm = value; }
    private int CurrentPage { get => State.CatalogCurrentPage; set => State.CatalogCurrentPage = value; }
    private bool HasMorePages { get => State.CatalogHasMorePages; set => State.CatalogHasMorePages = value; }

    @* New Filter State Redirection *@
    private int? SelectedCategoryId { get => State.SelectedCategoryId; set => State.SelectedCategoryId = value; }
    private int? SelectedGenreId { get => State.SelectedGenreId; set => State.SelectedGenreId = value; }
    private int? SelectedYear { get => State.SelectedYear; set => State.SelectedYear = value; }
    private string? SelectedSeason { get => State.SelectedSeason; set => State.SelectedSeason = value; }

    @* UI Data Lists *@
    private List<GenreReadDto> _genres => State.Genres;
    private List<CategoryReadDto> _categories => State.Categories;
    private List<int> _years = Enumerable.Range(1990, (DateTime.Now.Year - 1989) + 1).Reverse().ToList();
    private List<string> _seasons = new() { "Winter", "Spring", "Summer", "Fall" };

    private string SearchInput = string.Empty;
    private bool IsLoading { get; set; } = false;
    private bool IsInitialLoading { get; set; } = true; // NEW: Track first-time load
    private CancellationTokenSource _debounceCts = new();

    protected override async Task OnInitializedAsync()
    {
        SearchInput = FilterQuery;

        // ONLY fetch if we don't already have them in State
        if (!State.Genres.Any() || !State.Categories.Any())
        {
            var genresTask = LookUpService.GetGenresAsync();
            var categoriesTask = LookUpService.GetCategoriesAsync();
            await Task.WhenAll(genresTask, categoriesTask);

            State.Genres = await genresTask ?? new();
            State.Categories = await categoriesTask ?? new();
        }

        IsInitialLoading = false; // Data is now ready

        // If coming back from Anime Details, don't reload data
        if (AnimesList.Count == 0)
        {
            CurrentPage = 1;
            await LoadAnimes();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("setupInfiniteScroll", DotNetObjectReference.Create(this));
        }
    }

    private async Task LoadAnimes(bool append = false)
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            if (CurrentPage < 1) CurrentPage = 1;

            var (newAnimes, metadata) = await AnimeService.GetAnimeCatalogAsync(CurrentPage, 20, "title", FilterQuery, SelectedCategoryId, SelectedGenreId, SelectedYear, SelectedSeason);

            if (append)
                State.CatalogItems.AddRange(newAnimes ?? new());
            else
                State.CatalogItems = newAnimes ?? new();

            HasMorePages = metadata?.HasNext ?? false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnSearchChanged(string value)
    {
        SearchInput = value;
        _debounceCts.Cancel();
        _debounceCts = new();

        try
        {
            await Task.Delay(400, _debounceCts.Token);
            FilterQuery = value;
            CurrentPage = 1;
            HasMorePages = true;
            State.CatalogItems.Clear(); // Clear list for new search
            await LoadAnimes(append: false);
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnFilterChanged()
    {
        CurrentPage = 1;
        HasMorePages = true;
        State.CatalogItems.Clear();
        await LoadAnimes(append: false);
    }

    [JSInvokable]
    public async Task LoadMoreData()
    {
        if (!IsLoading && HasMorePages)
        {
            CurrentPage++;
            await LoadAnimes(append: true);
        }
    }

    public void Dispose()
    {
        _debounceCts.Cancel();
        _debounceCts.Dispose();
    }
}