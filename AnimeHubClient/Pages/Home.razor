@page "/"
@using AnimeHub.Shared.Models.Dtos
@using AnimeHub.Shared.Models.Dtos.Anime
@using AnimeHubClient.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IAnimeService AnimeService
@inject ILookUpService LookUpService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    @* --- 1. CINEMATIC BANNER --- *@
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <div style="position:relative; height:65vh;">
                <MudCarousel Class="mud-carousel-custom" Style="height:65vh" NextIcon="@Icons.Material.Outlined.ArrowCircleRight" PreviousIcon="@Icons.Material.Filled.ArrowCircleLeft" ShowArrows="true" AutoCycle="true" TData="object">
                    <MudCarouselItem Transition="Transition.Fade">
                        <div class="hero-image-overlay" style="background-image: url('/images/hero1.jpg');"></div>
                    </MudCarouselItem>
                    <MudCarouselItem Transition="Transition.Fade">
                        <div class="hero-image-overlay" style="background-image: url('/images/hero6.jpg');"></div>
                    </MudCarouselItem>
                    <MudCarouselItem Transition="Transition.Fade">
                        <div class="hero-image-overlay" style="background-image: url('/images/hero7.jpg');"></div>
                    </MudCarouselItem>
                    <MudCarouselItem Transition="Transition.Fade">
                        <div class="hero-image-overlay" style="background-image: url('/images/hero4.jpg');"></div>
                    </MudCarouselItem>
                </MudCarousel>

                @* Overlay section *@
                <div class="hero-content-overlay">
                    <div class="hero-content">
                        <h1 class="hero-title">Welcome to <span class="highlight">AnimeHub</span></h1>
                        <p class="hero-subtitle">Your destination for all things anime. Discover, rate, and explore a world of stories.</p>
                        <div class="hero-cta">
                            <MudButton Href="animes"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       Class="hero-cta-button">
                                Browse Anime
                            </MudButton>

                            <AuthorizeView>
                                <Authorized>
                                    <MudButton Href="/propose"
                                               Variant="Variant.Outlined"
                                               Color="Color.Info"
                                               Size="Size.Large"
                                               Class="hero-cta-button ms-2"
                                               Style="border-color: var(--mud-palette-info); color: white;">
                                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="me-1" Size="Size.Small" />Propose New
                                    </MudButton>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            </div>
        </MudItem>

        @* --- 2. TOP RATED SECTION --- *@
        <MudItem xs="12" Class="mt-8">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h5" Class="section-title-alt">Top Rated</MudText>
                <MudButton Variant="Variant.Text" EndIcon="@Icons.Material.Filled.ChevronRight" Href="/animes">View All</MudButton>
            </div>
            @if (IsLoading)
            {
                <MudGrid Justify="Justify.Center">
                    @for (int i = 0; i < 6; i++)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCardSkeleton />
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (TopRatedAnimes != null && TopRatedAnimes.Any())
            {
                <MudGrid Justify="Justify.Center" Spacing="4">
                    @foreach (var anime in TopRatedAnimes)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCard Anime="anime" />
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudText Align="Align.Center">No top-rated anime to display.</MudText>
            }
        </MudItem>

        @* --- 3. LATEST ANIME SECTION --- *@
        <MudItem xs="12" Class="mt-8">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h5" Class="section-title-alt">Latest Releases</MudText>
                <MudButton Variant="Variant.Text" EndIcon="@Icons.Material.Filled.ChevronRight" Href="/animes">View All</MudButton>
            </div>
            @if (IsLoading)
            {
                <MudGrid Justify="Justify.Center">
                    @for (int i = 0; i < 6; i++)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCardSkeleton />
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (LatestAnimes != null && LatestAnimes.Any())
            {
                <MudGrid Justify="Justify.Center" Spacing="4">
                    @foreach (var anime in LatestAnimes)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCard Anime="anime" />
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudText Align="Align.Center">No latest anime to display.</MudText>
            }
        </MudItem>

        @* --- 4. BROWSE BY CATEGORIES / GENRES / SEASONS --- *@
        <MudItem xs="12" md="4" Class="mt-8">
            <MudPaper Class="pa-6 glass-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4" StartIcon="@Icons.Material.Filled.Category">Formats</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var cat in Categories ?? new())
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary"
                                 OnClick="@(() => Navigation.NavigateTo($"/animes?categoryId={cat.Id}"))">@cat.Name</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="mt-8">
            <MudPaper Class="pa-6 glass-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Popular Genres</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var genre in Genres ?? new())
                    {
                        <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary"
                                 OnClick="@(() => Navigation.NavigateTo($"/animes?genreId={genre.Id}"))">@genre.Name</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="mt-8">
            <MudPaper Class="pa-6 glass-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Seasons</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var season in _seasons)
                    {
                        <MudChip T="string" Variant="Variant.Filled" Color="Color.Info"
                                 OnClick="@(() => Navigation.NavigateTo($"/animes?season={season}"))">@season</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool IsLoading { get; set; } = true;
    private List<AnimeListReadDto>? TopRatedAnimes;
    private List<AnimeListReadDto>? LatestAnimes;
    private List<CategoryReadDto>? Categories;
    private List<GenreReadDto>? Genres;
    private List<string> _seasons = new() { "Winter", "Spring", "Summer", "Fall" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var topRatedTask = AnimeService.GetTopRatedAnimesAsync();
            var latestTask = AnimeService.GetLatestAnimesAsync();
            var categoriesTask = LookUpService.GetCategoriesAsync();
            var genresTask = LookUpService.GetGenresAsync();

            await Task.WhenAll(topRatedTask, latestTask, categoriesTask, genresTask);

            TopRatedAnimes = (await topRatedTask)?.Take(6).ToList();
            LatestAnimes = (await latestTask)?.Take(6).ToList();
            Categories = await categoriesTask;
            Genres = await genresTask;
        }
        catch
        {
            Snackbar.Add("Error loading discovery sections.", Severity.Error);
        }
        finally
        {
            IsLoading = false;
        }
    }
}