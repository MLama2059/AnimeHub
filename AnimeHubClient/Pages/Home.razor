@page "/"
@using AnimeHub.Shared.Models.Dtos
@using AnimeHub.Shared.Models.Dtos.Anime
@using AnimeHubClient.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IAnimeService AnimeService
@inject ILookUpService LookUpService

<style>
    .hero-container {
        position: relative;
        border-radius: 28px;
        overflow: hidden;
        background: #0a0a0a;
        height: 65vh;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .hero-content-box {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 80px 5% 40px;
        background: linear-gradient(to top, rgba(12,12,12,1) 0%, rgba(12,12,12,0.8) 40%, transparent 100%);
        z-index: 10;
    }

    .section-title-alt {
        border-left: 5px solid var(--mud-palette-primary);
        padding-left: 15px;
        font-weight: 800;
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    @* --- 1. CINEMATIC BANNER --- *@
    <div class="hero-container mb-12">
        <MudCarousel Class="h-100" ShowArrows="false" ShowBullets="true" AutoCycle="true" TData="object">
            <MudCarouselItem Transition="Transition.Fade">
                <MudImage Src="/images/hero1.jpg" ObjectFit="ObjectFit.Cover" Class="w-100 h-100" />
            </MudCarouselItem>
            <MudCarouselItem Transition="Transition.Fade">
                <MudImage Src="/images/hero6.jpg" ObjectFit="ObjectFit.Cover" Class="w-100 h-100" />
            </MudCarouselItem>
        </MudCarousel>

        <div class="hero-content-box">
            <MudText Typo="Typo.h2" Class="fw-bold mb-2">Unleash Your <span class="mud-primary-text">Otaku</span> Spirit</MudText>
            <MudText Typo="Typo.h6" Class="text-muted mb-6" Style="max-width: 700px;">
                The most comprehensive anime database. Track your progress, discover hidden gems, and stay updated with the latest releases.
            </MudText>
            <div class="d-flex gap-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/animes" Style="height:55px; px-10; border-radius:15px;">
                    Explore Now
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Size="Size.Large" StartIcon="@Icons.Material.Filled.PlayCircle" Style="height:55px; border-radius:15px;">
                    Watch Trailer
                </MudButton>
            </div>
        </div>
    </div>

    <MudGrid Spacing="6">
        @* --- 2. TOP RATED SECTION --- *@
        <MudItem xs="12">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h5" Class="section-title-alt">Top Rated</MudText>
                <MudButton Variant="Variant.Text" EndIcon="@Icons.Material.Filled.ChevronRight" Href="/animes">View All</MudButton>
            </div>
            <MudGrid Spacing="4">
                @if (IsLoading)
                {
                    @for(int i = 0; i < 6; i++) {
                        <MudItem lg="2" md="3" sm="4" xs="6"><AnimeCardSkeleton /></MudItem>
                    }
                }
                else
                {
                    @foreach (var anime in TopRatedAnimes ?? new())
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6"><AnimeCard Anime="anime" /></MudItem>
                    }
                }
            </MudGrid>
        </MudItem>

        @* --- 3. LATEST ANIME SECTION --- *@
        <MudItem xs="12" Class="mt-8">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h5" Class="section-title-alt">Latest Releases</MudText>
            </div>
            <MudGrid Spacing="4">
                @if (IsLoading)
                {
                    @for(int i = 0; i < 6; i++) {
                        <MudItem lg="2" md="3" sm="4" xs="6"><AnimeCardSkeleton /></MudItem>
                    }
                }
                else
                {
                    @foreach (var anime in LatestAnimes ?? new())
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6"><AnimeCard Anime="anime" /></MudItem>
                    }
                }
            </MudGrid>
        </MudItem>

        @* --- 4. BROWSE BY CATEGORIES / GENRES / SEASONS --- *@
        <MudItem xs="12" md="4" Class="mt-8">
            <MudPaper Class="pa-6 glass-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4" StartIcon="@Icons.Material.Filled.Category">Formats</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var cat in Categories ?? new())
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary"
                                 OnClick="@(() => Navigation.NavigateTo($"/animes?categoryId={cat.Id}"))">@cat.Name</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="mt-8">
            <MudPaper Class="pa-6 glass-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Popular Genres</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var genre in Genres ?? new())
                    {
                        <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary"
                                 OnClick="@(() => Navigation.NavigateTo($"/animes?genreId={genre.Id}"))">@genre.Name</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="mt-8">
            <MudPaper Class="pa-6 glass-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Seasons</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var season in _seasons)
                    {
                        <MudChip T="string" Variant="Variant.Filled" Color="Color.Info"
                                 OnClick="@(() => Navigation.NavigateTo($"/animes?season={season}"))">@season</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool IsLoading { get; set; } = true;
    private List<AnimeListReadDto>? TopRatedAnimes;
    private List<AnimeListReadDto>? LatestAnimes;
    private List<CategoryReadDto>? Categories;
    private List<GenreReadDto>? Genres;
    private List<string> _seasons = new() { "Winter", "Spring", "Summer", "Fall" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var topRatedTask = AnimeService.GetTopRatedAnimesAsync();
            var latestTask = AnimeService.GetLatestAnimesAsync(); // Ensure this exists in your service
            var categoriesTask = LookUpService.GetCategoriesAsync();
            var genresTask = LookUpService.GetGenresAsync();

            await Task.WhenAll(topRatedTask, latestTask, categoriesTask, genresTask);

            TopRatedAnimes = (await topRatedTask)?.Take(6).ToList();
            LatestAnimes = (await latestTask)?.Take(6).ToList();
            Categories = await categoriesTask;
            Genres = await genresTask;
        }
        catch { Snackbar.Add("Error loading discovery sections.", Severity.Error); }
        finally { IsLoading = false; }
    }
}