@page "/"
@using AnimeHub.Shared.Models.Dtos
@using AnimeHub.Shared.Models.Dtos.Anime
@using AnimeHubClient.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IAnimeService AnimeService
@inject ILookUpService LookUpService

<style>
    /* HERO FIXES */
    
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    @* HERO SECTION *@
    <div class="hero-wrapper">
        <MudCarousel Class="h-100" ShowArrows="false" ShowBullets="true" AutoCycle="true" TData="object">
            <MudCarouselItem Transition="Transition.Fade">
                <MudImage Src="/images/hero1.jpg" ObjectFit="ObjectFit.Cover" Class="w-100 h-100" />
            </MudCarouselItem>
            <MudCarouselItem Transition="Transition.Fade">
                <MudImage Src="/images/hero6.jpg" ObjectFit="ObjectFit.Cover" Class="w-100 h-100" />
            </MudCarouselItem>
            <MudCarouselItem Transition="Transition.Fade">
                <MudImage Src="/images/hero7.jpg" ObjectFit="ObjectFit.Cover" Class="w-100 h-100" />
            </MudCarouselItem>
        </MudCarousel>

        <div class="hero-overlay-cinematic"></div>

        <div class="hero-content-left">
            <h1 class="hero-title-large">
                Your Anime <br />
                Universe <span style="color:var(--mud-palette-primary)">Refined.</span>
            </h1>
            <p class="hero-description mt-6 mb-10">
                Join thousands of fans tracking their favorite series.
                Rate, review, and organize your anime journey in one place.
            </p>

            <div class="d-flex gap-4">
                <MudButton Href="animes" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="border-radius:12px; height:54px;">
                    Start Browsing
                </MudButton>
                
                <AuthorizeView>
                    <Authorized>
                        <MudButton Href="/proposal-anime" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Large" Style="border-radius:12px; height:54px;">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Class="me-2" /> Propose New
                        </MudButton>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>

    @* CONTENT ROWS *@
    <MudGrid Justify="Justify.Center">
        @* Top Rated *@
        <MudItem xs="12" Class="mt-10">
            <div class="d-flex align-center justify-space-between mb-6">
                <MudText Typo="Typo.h5" Class="section-title-alt">Top Rated</MudText>
                <MudButton Href="/animes" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ChevronRight">All Anime</MudButton>
            </div>

            @if (IsLoading)
            {
                <MudGrid Justify="Justify.Center">
                    @for (int i = 0; i < 6; i++)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCardSkeleton />
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (TopRatedAnimes != null && TopRatedAnimes.Any())
            {
                <MudGrid Justify="Justify.Center" Spacing="4">
                    @foreach (var anime in TopRatedAnimes)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCard Anime="anime" />
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudText Align="Align.Center">No top-rated anime to display.</MudText>
            }
        </MudItem>

        @* Latest Releases *@
        <MudItem xs="12" Class="mt-10">
            <div class="d-flex align-center justify-space-between mb-6">
                <MudText Typo="Typo.h5" Class="section-title-alt">Latest Updates</MudText>
            </div>

            @if (IsLoading)
            {
                <MudGrid Justify="Justify.Center">
                    @for (int i = 0; i < 6; i++)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCardSkeleton />
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (LatestAnimes != null && LatestAnimes.Any())
            {
                <MudGrid Justify="Justify.Center" Spacing="4">
                    @foreach (var anime in LatestAnimes)
                    {
                        <MudItem lg="2" md="3" sm="4" xs="6" Class="d-flex justify-content-center">
                            <AnimeCard Anime="anime" />
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudText Align="Align.Center">No latest anime to display.</MudText>
            }
        </MudItem>

        @* DISCOVERY CHIPS *@
        <MudItem xs="12" md="4" Class="mt-10">
            <MudPaper Class="pa-6 glass-card h-100" Elevation="1">
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold mb-4">Formats</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var cat in Categories ?? new())
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo($"/animes?categoryId={cat.Id}"))">@cat.Name</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="mt-10">
            <MudPaper Class="pa-6 glass-card h-100" Elevation="2">
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="fw-bold mb-4">Popular Genres</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var genre in PopularGenres ?? new())
                    {
                        <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary" OnClick="@(() => Navigation.NavigateTo($"/animes?genreId={genre.Id}"))">@genre.Name</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="mt-10">
            <MudPaper Class="pa-6 glass-card h-100" Elevation="3">
                <MudText Typo="Typo.h6" Color="Color.Info" Class="fw-bold mb-4">Seasons</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var season in Seasons)
                    {
                        <MudChip T="string" Variant="Variant.Filled" Color="Color.Info" OnClick="@(() => Navigation.NavigateTo($"/animes?season={season}"))">@season</MudChip>
                    }
                </div>
            </MudPaper>
        </MudItem>

        @* FOOTER *@
        <MudItem xs="12">
            <div class="footer-cta shadow-lg">
                <MudText Typo="Typo.h4" Class="fw-bold mb-2">Ready to start your watchlist?</MudText>
                <MudText Typo="Typo.body1" Class="mb-8" Style="opacity: 0.7">Create an account to keep track of every episode you watch.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/register" Style="px-12; height:50px; border-radius:12px;">
                    Get Started Free
                </MudButton>
                <div class="mt-12">
                    <MudText Typo="Typo.caption" Style="opacity: 0.5;">&copy; @DateTime.Now.Year AnimeHub. All rights reserved.</MudText>
                </div>
            </div>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool IsLoading { get; set; } = true;
    private List<AnimeListReadDto>? TopRatedAnimes;
    private List<AnimeListReadDto>? LatestAnimes;
    private List<CategoryReadDto>? Categories;
    private List<GenreReadDto>? PopularGenres;
    private List<string> Seasons = new() { "Winter", "Spring", "Summer", "Fall" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var topRatedTask = AnimeService.GetTopRatedAnimesAsync();
            var latestTask = AnimeService.GetLatestAnimesAsync();
            var categoriesTask = LookUpService.GetCategoriesAsync();
            var genresTask = LookUpService.GetGenresAsync();

            await Task.WhenAll(topRatedTask, latestTask, categoriesTask, genresTask);

            TopRatedAnimes = (await topRatedTask)?.Take(6).ToList();
            LatestAnimes = (await latestTask)?.Take(6).ToList();
            Categories = await categoriesTask;
            
            // LOGIC: Static Popularity Priority
            var allGenres = await genresTask ?? new();
            var priorityGenres = new List<string> { "Action", "Adventure", "Comedy", "Drama", "Fantasy", "Romance", "Sci-Fi", "Slice of Life", "Supernatural", "Mystery" };
            
            PopularGenres = allGenres
                .OrderByDescending(g => priorityGenres.Contains(g.Name))
                .ThenBy(g => g.Name)
                .Take(10)
                .ToList();
        }
        catch { Snackbar.Add("Connection issues. Please try again later.", Severity.Error); }
        finally { IsLoading = false; }
    }
}